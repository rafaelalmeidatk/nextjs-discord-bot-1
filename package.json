{
  "name": "next-bot",
  "version": "1.0.0",
  "author": "Rafael Almeida",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "start": "node src/index.ts",
    "dev": "node --watch src/index.ts",
    "dev:register-commands": "DEV=true node src/register-commands.ts",
    "register-commands": "node src/register-commands.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write \"**/*.{ts,tsx}\""
  },
  "dependencies": {
    "discord.js": "14.26.3",
    "dotenv": "16.3.1"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@typescript-eslint/eslint-plugin": "6.4.1",
    "@typescript-eslint/parser": "6.4.1",
    "eslint": "8.47.0",
    "eslint-config-prettier": "9.0.0",
    "eslint-plugin-prettier": "5.0.0",
    "prettier": "3.0.2",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.4"
}
